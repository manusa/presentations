{
  "name": "@marcnuri/presentations",
  "version": "0.13.0",
  "description": "Marc Nuri Tech Talks presentations",
  "bin": {
    "mn-presentations": "index.js"
  },
  "main": "index.js",
  "scripts": {
    "build": "gatsby clean &  gatsby build",
    "dev": "gatsby develop --host=0.0.0.0",
    "develop": "gatsby develop --host=0.0.0.0",
    "start": "npm run develop --host=0.0.0.0",
    "test": "jest",
    "screenshot": "node scripts/screenshot.js",
    "screenshot:setup": "playwright install chromium",
    "screenshot:deck": "node scripts/screenshot-deck.js",
    "serve:static": "npm run gen:landing && node scripts/serve-static.js",
    "serve:static:stop": "node scripts/serve-static-stop.js",
    "optimize:images": "node scripts/optimize-images.js",
    "gen:landing": "node scripts/generate-landing.js",
    "gen:qr": "node scripts/gen-qr.js",
    "export:pdf": "node scripts/export-pdf.js",
    "snapshot:baseline": "node scripts/snapshot-baseline.js",
    "snapshot:diff": "node scripts/snapshot-diff.js",
    "audit:fit": "node scripts/audit-fit.js",
    "test:deck-kit": "node --test tests/deck-kit/*.spec.js",
    "test:pdf-links": "node scripts/test-pdf-links.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "public"
  ],
  "keywords": [],
  "author": {
    "name": "Marc Nuri",
    "url": "https://blog.marcnuri.com"
  },
  "license": "Apache-2.0",
  "licenses": [
    {
      "type": "Apache-2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manusa/presentations.git"
  },
  "bugs": {
    "url": "https://github.com/manusa/presentations/issues"
  },
  "homepage": "https://github.com/manusa/presentations#readme",
  "dependencies": {
    "@fortawesome/fontawesome-free": "6.7.2",
    "gatsby": "5.14.5",
    "gatsby-plugin-react-helmet": "6.14.0",
    "gatsby-plugin-sass": "6.14.0",
    "react": "18.3.1",
    "react-archer": "4.4.0",
    "react-dom": "18.3.1",
    "react-helmet": "6.1.0",
    "react-syntax-highlighter": "15.6.1",
    "sass": "1.101.0"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/deck-kit/",
      "/tests/pdf-links/"
    ]
  },
  "devDependencies": {
    "eslint": "8.57.1",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-react": "7.37.5",
    "jest": "30.4.2",
    "live-server": "1.2.2",
    "pdf-lib": "1.17.1",
    "pixelmatch": "7.2.0",
    "playwright": "1.60.0",
    "pngjs": "7.0.0",
    "prop-types": "15.8.1",
    "qrcode": "1.5.4",
    "sharp": "0.35.2"
  }
}
